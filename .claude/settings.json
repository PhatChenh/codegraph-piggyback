{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codegraph-piggyback/codegraph-gate/codegraph-gate.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__codegraph__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codegraph-piggyback/codegraph-gate/codegraph-gate.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codegraph-piggyback/codegraph-gate/codegraph-gate.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
